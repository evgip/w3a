# ═══════════════════════════════════════════
# ОКРУЖЕНИЕ
# ═══════════════════════════════════════════
APP_ENV=development
APP_URL=http://localhost
APP_LANG=ru

# ═══════════════════════════════════════════
# БАЗА ДАННЫХ
# ═══════════════════════════════════════════
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database
DB_USER=root
DB_PASS=

# ═══════════════════════════════════════════
# СЕССИЯ
# ═══════════════════════════════════════════
SESSION_NAME=w3a_session

# ═══════════════════════════════════════════
# КАПЧА
# ═══════════════════════════════════════════
CAPTCHA_ENABLED=true
CAPTCHA_DRIVER=yandex

# Yandex SmartCaptcha
YANDEX_CAPTCHA_SITE_KEY=your-site-key-here
YANDEX_CAPTCHA_SECRET_KEY=your-secret-key-here
YANDEX_CAPTCHA_SUBMIT_URL=https://smartcaptcha.cloud.yandex.ru/validate

# Google reCAPTCHA
GOOGLE_CAPTCHA_SITE_KEY=
GOOGLE_CAPTCHA_SECRET_KEY=
GOOGLE_CAPTCHA_SUBMIT_URL=https://www.google.com/recaptcha/api/siteverify

# ═══════════════════════════════════════════
# EMAIL (SMTP через PHPMailer)
# ═══════════════════════════════════════════
MAIL_HOST=smtp.yandex.ru
MAIL_PORT=465
MAIL_AUTH=true
MAIL_USERNAME=your-login@yandex.ru
MAIL_PASSWORD=your-password
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@soc.local
MAIL_FROM_NAME=w3a
MAIL_PRETEND=false
MAIL_DEBUG=0